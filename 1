# ---------------- SCAN STATUS ----------------
scan_status = {}

# ---------------- SECURITY ----------------
@app.before_request
def check_api_key():
    # Allow homepage and static files
    if request.path in ["/", "/dashboard", "/new-scan", "/history", "/learning"] or request.path.startswith("/static"):
        return
    # Protect API routes
    if request.path.startswith("/api"):
        if request.headers.get("X-API-Key") != API_KEY:
            return {"error": "Unauthorized"}, 401

# ---------------- AI ----------------
def call_ollama(recon_results):
    prompt = f"""
You are an autonomous penetration tester.
Given the following findings:
{recon_results}
Return structured attack chain in JSON format:
{{
 "steps": [
   {{"step":1,"action":"recon"}},
   {{"step":2,"action":"exploit"}},
   {{"step":3,"action":"privilege escalation"}}
 ]
}}
"""
    try:
        response = requests.post(
            OLLAMA_URL,
            json={"model": "llama3", "prompt": prompt, "stream": False},
            timeout=120
        )
        data = response.json()
        return data.get("response", "")
    except Exception as e:
        print("AI ERROR:", e)
        return ""

def extract_json(text):
    try:
        if isinstance(text, dict):
            return text
        import re
        matches = re.findall(r'\{.*\}', text, re.DOTALL)
        return json.loads(matches[0]) if matches else {}
    except Exception:
        return {}

def calculate_summary(findings):
    summary = {"High": 0, "Medium": 0, "Low": 0}
    if isinstance(findings, list):
        for f in findings:
            sev = f.get("severity")
            if sev in summary:
                summary[sev] += 1
    return summary

# ---------------- BACKGROUND SCAN ----------------
def run_scan_background(scan_id, target):
    try:
        scan_status[scan_id] = "Starting Nmap"
        raw_nmap = run_nmap(target)
        nmap_results = parse_nmap_output(raw_nmap)

        scan_status[scan_id] = "Recon"
        recon_results = basic_recon(target)

        scan_status[scan_id] = "Vuln Mapping"
        vulnerabilities = map_vulnerabilities(nmap_results)

        scan_status[scan_id] = "Metasploit"
        msf_results = []
        for port in nmap_results:
            if port.get("port") == "21":
                msf_results.append(run_msf_module("scanner/ftp/ftp_version", target))
            if port.get("port") == "445":
                msf_results.append(run_msf_module("scanner/smb/smb_version", target))

        scan_status[scan_id] = "AI Reasoning"
        ai_raw = call_ollama(recon_results)
        attack_chain = extract_json(ai_raw).get("steps", [])

        # Build final result
        result = {
            "scan_id": scan_id,
            "target": target,
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "nmap": nmap_results,
            "findings": recon_results,
            "vulnerabilities": vulnerabilities,
            "attack_chain": attack_chain,
            "metasploit": msf_results,
            "ai_analysis": ai_raw,
            "summary": calculate_summary(recon_results),
            "status": "Completed"
        }

        file_path = f"storage/findings/{scan_id}.json"
        with open(file_path, "w") as f:
            json.dump(result, f, indent=4)

        scan_status[scan_id] = "Completed"
    except Exception as e:
        scan_status[scan_id] = "Failed"
        print(f"[SCAN ERROR] {scan_id}: {e}")

