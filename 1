from flask import send_file

@app.route("/api/report/pdf/<scan_id>")
def generate_pdf(scan_id):
    # Optional: allow query param for browser
    key = request.args.get("key")
    if key != API_KEY:
        # For AJAX requests, also check header
        if request.headers.get("X-API-Key") != API_KEY:
            return {"error": "Unauthorized"}, 401

    file_path = f"storage/findings/{scan_id}.json"

    if not os.path.exists(file_path):
        return {"error": "Scan not found"}, 404

    with open(file_path) as f:
        data = json.load(f)

    pdf_path = f"storage/findings/{scan_id}.pdf"

    from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
    from reportlab.lib.styles import getSampleStyleSheet

    doc = SimpleDocTemplate(pdf_path)
    styles = getSampleStyleSheet()
    content = []

    # Add basic info
    content.append(Paragraph(f"Scan ID: {data.get('scan_id','N/A')}", styles["Heading2"]))
    content.append(Paragraph(f"Target: {data.get('target','N/A')}", styles["Normal"]))
    content.append(Paragraph(f"Timestamp: {data.get('timestamp','N/A')}", styles["Normal"]))
    content.append(Spacer(1,12))

    # Add summary
    summary = data.get("summary", {})
    summary_text = f"High: {summary.get('High',0)}, Medium: {summary.get('Medium',0)}, Low: {summary.get('Low',0)}"
    content.append(Paragraph(f"Summary: {summary_text}", styles["Normal"]))
    content.append(Spacer(1,12))

    # Add Nmap results
    nmap_results = data.get("nmap", [])
    content.append(Paragraph("Open Ports:", styles["Heading3"]))
    for port in nmap_results:
        line = f"Port: {port.get('port','N/A')}, Service: {port.get('service','N/A')}, Severity: {port.get('severity','N/A')}"
        content.append(Paragraph(line, styles["Normal"]))
    content.append(Spacer(1,12))

    # Add findings
    findings = data.get("findings", [])
    content.append(Paragraph("Recon Findings:", styles["Heading3"]))
    if findings:
        for idx,f in enumerate(findings,1):
            title = f.get("title", f"Finding {idx}")
            severity = f.get("severity","N/A")
            desc = f.get("description","")
            content.append(Paragraph(f"{title} (Severity: {severity}) - {desc}", styles["Normal"]))
            content.append(Spacer(1,6))
    else:
        content.append(Paragraph("No findings recorded.", styles["Normal"]))
    content.append(Spacer(1,12))

    # Add AI analysis
    ai_analysis = data.get("ai_analysis","")
    if isinstance(ai_analysis, dict):
        ai_analysis = json.dumps(ai_analysis, indent=2)  # Convert dict to text
    content.append(Paragraph("AI Analysis:", styles["Heading3"]))
    content.append(Paragraph(str(ai_analysis), styles["Normal"]))

    # Build PDF
    doc.build(content)

    # Serve PDF to browser
    return send_file(pdf_path, as_attachment=True)
