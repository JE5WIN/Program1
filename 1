@app.before_request
def check_api_key():
    # Allow homepage and static files
    if request.path == "/" or request.path.startswith("/static"):
        return

    # Allow dashboard pages without API key
    if request.path.startswith("/dashboard") or request.path.startswith("/index"):
        return

    # Protect API endpoints except public ones
    if request.path.startswith("/api"):
        # Add exception for PDF download if you want browser access
        if request.path.startswith("/api/report/pdf/"):
            return  # Allow direct browser download

        if request.headers.get("X-API-Key") != API_KEY:
            return {"error": "Unauthorized"}, 401
