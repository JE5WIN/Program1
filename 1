// ---------------- CONFIG ----------------
const API_KEY = "jeswin2026";

// ---------------- TAB NAVIGATION ----------------
function showMainTab(tabId, el) {
    const tabs = document.querySelectorAll(".tab-panel");
    tabs.forEach(tab => tab.classList.add("hidden"));

    const buttons = document.querySelectorAll(".tab-btn");
    buttons.forEach(btn => btn.classList.remove("active"));

    document.getElementById(tabId).classList.remove("hidden");
    el.classList.add("active");
}

// ---------------- SCAN ----------------
async function startScan() {
    const targetInput = document.getElementById("target");
    const statusEl = document.getElementById("scanStatus");
    const target = targetInput.value.trim();

    if (!target) {
        statusEl.innerText = "Please enter a target IP or domain.";
        return;
    }

    statusEl.innerText = "Starting scan...";

    try {
        const response = await fetch("/api/scan", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-API-Key": API_KEY
            },
            body: JSON.stringify({ target: target })
        });

        const data = await response.json();

        if (!response.ok) {
            statusEl.innerText = data.error || "Failed to start scan.";
            return;
        }

        const scanId = data.scan_id;
        statusEl.innerText = `Scan started. Scan ID: ${scanId}`;

        // Poll results live
        pollScanResults(scanId);

    } catch (error) {
        console.error("Start scan error:", error);
        statusEl.innerText = "Error starting scan.";
    }
}

// ---------------- POLLING / LIVE UPDATE ----------------
async function pollScanResults(scanId) {
    const statusEl = document.getElementById("scanStatus");

    const interval = setInterval(async () => {
        try {
            const response = await fetch(`/api/result/${scanId}`, {
                headers: { "X-API-Key": API_KEY }
            });
            const data = await response.json();

            // Update status based on backend stage
            statusEl.innerText = `Status: ${scan_status_map(data.status)}`;

            // Incrementally update UI
            if (data.nmap) renderPorts(data.nmap);
            if (data.findings) renderFindings(data.findings);
            if (data.vulnerabilities) renderVulnerabilities(data.vulnerabilities);
            if (data.attack_chain) renderAttackChain(data.attack_chain);
            if (data.metasploit) renderMetasploit(data.metasploit);
            if (data.ai_analysis) renderAIReadable(data.ai_analysis);
            if (data.summary) renderOverviewSummary(data.summary, data);

            // Stop polling when completed
            if (data.status === "Completed") {
                clearInterval(interval);
                showMainTab('overviewTab', document.querySelector(".tab-btn.active"));
                statusEl.innerText = "Scan Completed";
            }
        } catch (error) {
            console.error("Polling error:", error);
            clearInterval(interval);
            statusEl.innerText = "Error checking scan status.";
        }
    }, 2000); // every 2 sec
}

// Map backend statuses to readable text
function scan_status_map(status) {
    switch(status) {
        case "Nmap": return "Running Nmap Scan";
        case "Recon": return "Running Recon Engine";
        case "Metasploit": return "Running Metasploit Modules";
        case "AI": return "Generating AI Attack Chain";
        case "Completed": return "Scan Completed";
        case "Failed": return "Scan Failed";
        default: return status;
    }
}

// ---------------- RENDER FUNCTIONS ----------------
function renderOverviewSummary(summary, data) {
    document.getElementById("summaryPorts").innerText = data.nmap?.length || 0;
    document.getElementById("summaryHigh").innerText = summary.High ?? 0;
    document.getElementById("summaryMedium").innerText = summary.Medium ?? 0;
    document.getElementById("summaryLow").innerText = summary.Low ?? 0;
    document.getElementById("summaryVulns").innerText = data.vulnerabilities?.length || 0;

    // Overview content
    const overviewEl = document.getElementById("overviewContent");
    overviewEl.innerHTML = `
        <div class="result-box">
            <p><strong>Scan ID:</strong> ${escapeHtml(data.scan_id || "N/A")}</p>
            <p><strong>Target:</strong> ${escapeHtml(data.target || "N/A")}</p>
            <p><strong>Timestamp:</strong> ${escapeHtml(data.timestamp || "N/A")}</p>
        </div>
    `;
}

function renderPorts(ports) {
    const el = document.getElementById("portsContent");
    if (!Array.isArray(ports) || ports.length === 0) {
        el.innerHTML = `<p class="empty-state">No open ports found.</p>`;
        return;
    }

    const rows = ports.map(port => `
        <tr>
            <td>${escapeHtml(port.port || "N/A")}</td>
            <td>${escapeHtml(port.protocol || "N/A")}</td>
            <td>${escapeHtml(port.service || "N/A")}</td>
            <td>${escapeHtml(port.state || "N/A")}</td>
        </tr>
    `).join("");

    el.innerHTML = `
        <table>
            <thead>
                <tr>
                    <th>Port</th>
                    <th>Protocol</th>
                    <th>Service</th>
                    <th>State</th>
                </tr>
            </thead>
            <tbody>${rows}</tbody>
        </table>
    `;
}

function renderFindings(findings) {
    const el = document.getElementById("findingsContent");
    if (!Array.isArray(findings) || findings.length === 0) {
        el.innerHTML = `<p class="empty-state">No findings available.</p>`;
        return;
    }

    el.innerHTML = findings.map((f,i) => `
        <div class="result-box">
            <h4>Finding ${i+1}</h4>
            <p><strong>Title:</strong> ${escapeHtml(f.title || "N/A")}</p>
            <p><strong>Severity:</strong> ${escapeHtml(f.severity || "N/A")}</p>
            <p><strong>Description:</strong> ${escapeHtml(f.description || JSON.stringify(f))}</p>
        </div>
    `).join("");
}

function renderVulnerabilities(vulns) {
    const el = document.getElementById("vulnerabilitiesContent");
    if (!Array.isArray(vulns) || vulns.length === 0) {
        el.innerHTML = `<p class="empty-state">No vulnerabilities mapped.</p>`;
        return;
    }

    el.innerHTML = vulns.map((v,i) => `
        <div class="result-box">
            <h4>Vulnerability ${i+1}</h4>
            <p><strong>Name:</strong> ${escapeHtml(v.name || v.title || "N/A")}</p>
            <p><strong>Severity:</strong> ${escapeHtml(v.severity || "N/A")}</p>
            <p><strong>Description:</strong> ${escapeHtml(v.description || JSON.stringify(v))}</p>
        </div>
    `).join("");
}

function renderAttackChain(chain) {
    const el = document.getElementById("attackChainContent");
    if (!Array.isArray(chain) || chain.length === 0) {
        el.innerHTML = `<p class="empty-state">No attack chain generated.</p>`;
        return;
    }

    const items = chain.map((step, idx) => `<li>Step ${idx+1}: ${escapeHtml(step.action || step.technique || "")}</li>`).join("");
    el.innerHTML = `<ol>${items}</ol>`;
}

function renderMetasploit(results) {
    const el = document.getElementById("metasploitContent");
    if (!Array.isArray(results) || results.length === 0) {
        el.innerHTML = `<p class="empty-state">No Metasploit results available.</p>`;
        return;
    }

    el.innerHTML = results.map((r,i) => `
        <div class="result-box">
            <h4>Metasploit Output ${i+1}</h4>
            <pre>${escapeHtml(typeof r === "string" ? r : JSON.stringify(r,null,2))}</pre>
        </div>
    `).join("");
}

function renderAIReadable(ai) {
    const el = document.getElementById("rawAiContent");
    if (!ai) { el.innerHTML = `<p class="empty-state">No AI analysis yet.</p>`; return; }

    if (typeof ai === "string") {
        try { ai = JSON.parse(ai); } catch(e) {}
    }

    let html = "";
    if (ai.attack_chain) {
        html += "<h4>Attack Chain:</h4><ol>";
        ai.attack_chain.forEach((s,i) => html += `<li>Step ${i+1}: ${escapeHtml(s.action || s.technique || "")}</li>`);
        html += "</ol>";
    }
    if (ai.risk_level) html += `<p><strong>Risk Level:</strong> ${ai.risk_level}</p>`;
    if (ai.mitigation) {
        html += "<h4>Mitigation:</h4><ul>";
        ai.mitigation.forEach(m => html += `<li>${escapeHtml(m.recommendation || m)}</li>`);
        html += "</ul>";
    }

    el.innerHTML = html;
}

// ---------------- UTILITY ----------------
function escapeHtml(value) {
    return String(value)
        .replace(/&/g,"&amp;")
        .replace(/</g,"&lt;")
        .replace(/>/g,"&gt;")
        .replace(/"/g,"&quot;")
        .replace(/'/g,"&#039;");
}
