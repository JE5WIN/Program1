from flask import Flask, request, jsonify, render_template, send_file
import json
import os
import requests
import uuid
import threading
import time
from datetime import timezone, datetime
from engine.recon import basic_recon
from engine.nmap_scanner import run_nmap
from engine.nmap_parser import parse_nmap_output
from engine.vuln_mapper import map_vulnerabilities
from engine.metasploit_executor import run_msf_module
from reportlab.platypus import SimpleDocTemplate, Paragraph
from reportlab.lib.styles import getSampleStyleSheet

# CONFIG
API_KEY = "jeswin2026"
OLLAMA_URL = "http://10.0.2.2:11434/api/generate"

app = Flask(__name__)
os.makedirs("storage/findings", exist_ok=True)

# Track scan status for incremental updates
scan_status = {}

# ---------------- SECURITY ----------------
@app.before_request
def check_api_key():
    if request.path == "/" or request.path.startswith("/static"):
        return
    if request.path.startswith("/api"):
        if request.headers.get("X-API-Key") != API_KEY:
            return {"error": "Unauthorized"}, 401

# ---------------- AI ----------------
def call_ollama(recon_results):
    """Call local Ollama AI and return human-readable JSON"""
    prompt = f"""
You are an autonomous penetration tester.

Findings:
{recon_results}

Return structured JSON (human readable):

{{
 "steps": [
    {{"step": 1, "action": "Recon"}},
    {{"step": 2, "action": "Exploit"}},
    {{"step": 3, "action": "Privilege Escalation"}}
 ],
 "risk_level": "",
 "explanation": "",
 "mitigation": []
}}
"""
    try:
        start = time.time()
        response = requests.post(
            OLLAMA_URL,
            json={"model": "llama3", "prompt": prompt, "stream": False},
            timeout=120
        )
        data = response.json()
        response_text = data.get("response", "")
        print("AI TIME:", time.time() - start)
        return response_text.strip()
    except Exception as e:
        print("AI ERROR:", e)
        return ""

def extract_json(text):
    try:
        import re
        matches = re.findall(r'\{.*\}', text, re.DOTALL)
        return json.loads(matches[0]) if matches else {}
    except Exception as e:
        print("JSON extract error:", e)
        return {}

def calculate_summary(findings):
    summary = {"High": 0, "Medium": 0, "Low": 0}
    for f in findings or []:
        sev = f.get("severity")
        if sev in summary:
            summary[sev] += 1
    return summary

# ---------------- BACKGROUND SCAN ----------------
def run_scan_background(scan_id, target):
    try:
        scan_status[scan_id] = "Running Nmap"
        raw_nmap = run_nmap(target)
        nmap_results = parse_nmap_output(raw_nmap)

        scan_status[scan_id] = "Recon"
        recon_results = basic_recon(target)

        scan_status[scan_id] = "Vulnerability Mapping"
        vuln_map = map_vulnerabilities(nmap_results)

        scan_status[scan_id] = "Metasploit"
        msf_results = []
        for port in nmap_results:
            if port.get("port") == "21":
                msf_results.append(run_msf_module("scanner/ftp/ftp_version", target))
            if port.get("port") == "445":
                msf_results.append(run_msf_module("scanner/smb/smb_version", target))

        scan_status[scan_id] = "AI Reasoning"
        ai_raw = call_ollama(recon_results)
        attack_chain = extract_json(ai_raw).get("steps", [])

        # Final result JSON
        result = {
            "scan_id": scan_id,
            "target": target,
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "nmap": nmap_results,
            "findings": recon_results,
            "vulnerabilities": vuln_map,
            "attack_chain": attack_chain,
            "metasploit": msf_results,
            "ai_analysis": ai_raw,
            "summary": calculate_summary(recon_results),
            "status": "Completed"
        }

        file_path = f"storage/findings/{scan_id}.json"
        with open(file_path, "w") as f:
            json.dump(result, f, indent=4)

        scan_status[scan_id] = "Completed"
        print(f"[SCAN DONE] {scan_id}")

    except Exception as e:
        scan_status[scan_id] = "Failed"
        print("Scan Error:", e)

# ---------------- ROUTES ----------------
@app.route("/")
def index():
    return render_template("index.html")

@app.route("/dashboard")
def dashboard():
    return render_template("dashboard.html")

@app.route("/new-scan")
def new_scan_page():
    return render_template("new-scan.html")

@app.route("/api/scan", methods=["POST"])
def api_scan():
    data = request.get_json()
    target = data.get("target")
    if not target:
        return {"error": "Target required"}, 400

    scan_id = str(uuid.uuid4())
    scan_status[scan_id] = "Starting"

    # Run scan in background thread
    thread = threading.Thread(target=run_scan_background, args=(scan_id, target))
    thread.start()

    return jsonify({"scan_id": scan_id, "status": "started"})

@app.route("/api/status/<scan_id>")
def api_status(scan_id):
    return {"status": scan_status.get(scan_id, "Unknown")}

@app.route("/api/result/<scan_id>")
def api_result(scan_id):
    file_path = f"storage/findings/{scan_id}.json"
    if not os.path.exists(file_path):
        return {"error": "Not ready"}, 404
    with open(file_path) as f:
        return json.load(f)

@app.route("/api/scans")
def api_scans():
    scans = []
    for file in os.listdir("storage/findings"):
        if file.endswith(".json"):
            with open(os.path.join("storage/findings", file)) as f:
                data = json.load(f)
            scans.append({
                "scan_id": data.get("scan_id"),
                "target": data.get("target"),
                "timestamp": data.get("timestamp"),
                "summary": data.get("summary")
            })
    return jsonify(scans)

# ---------------- PDF EXPORT ----------------
@app.route("/api/report/pdf/<scan_id>")
def generate_pdf(scan_id):
    file_path = f"storage/findings/{scan_id}.json"
    if not os.path.exists(file_path):
        return {"error": "Not found"}, 404

    with open(file_path) as f:
        data = json.load(f)

    pdf_path = f"storage/findings/{scan_id}.pdf"
    doc = SimpleDocTemplate(pdf_path)
    styles = getSampleStyleSheet()
    content = []

    content.append(Paragraph(f"Target: {data['target']}", styles["Normal"]))
    content.append(Paragraph(f"Timestamp: {data['timestamp']}", styles["Normal"]))
    content.append(Paragraph(f"Summary: {json.dumps(data['summary'], indent=2)}", styles["Normal"]))
    content.append(Paragraph("Findings:", styles["Normal"]))
    for f in data.get("findings", []):
        content.append(Paragraph(json.dumps(f, indent=2), styles["Normal"]))

    content.append(Paragraph("Vulnerabilities:", styles["Normal"]))
    for v in data.get("vulnerabilities", []):
        content.append(Paragraph(json.dumps(v, indent=2), styles["Normal"]))

    content.append(Paragraph("Attack Chain:", styles["Normal"]))
    for a in data.get("attack_chain", []):
        content.append(Paragraph(json.dumps(a, indent=2), styles["Normal"]))

    doc.build(content)
    return send_file(pdf_path, as_attachment=True)

# ---------------- RUN ----------------
if __name__ == "__main__":
    app.run(debug=True)
