{% extends "base.html" %}

{% block title %}New Scan - AI Pentest{% endblock %}

{% block content %}
<div class="topbar">
    <div>
        <div class="page-title">Start New Scan</div>
        <div class="page-sub">Launch scan and redirect to full result page when complete</div>
    </div>
    <div class="status-pill" id="topStatus">Ready</div>
</div>

<section class="card">
    <div class="section-title">Target Input</div>
    <div class="scan-form-grid">
        <input type="text" id="target" placeholder="Enter target IP or domain">
        <button class="btn" onclick="startScan()">Start Scan</button>
        <button class="btn secondary" onclick="resetScanInput()">Clear</button>
    </div>

    <div id="scanStatus" style="margin-top: 14px; color:#93c5fd; font-weight:bold;">
        Waiting to start scan.
    </div>

    <div class="progress-wrap">
        <div class="progress-track">
            <div id="progressFill" class="progress-fill"></div>
        </div>
        <div class="phase-row">
            <div class="phase-chip" id="phase-start">Start</div>
            <div class="phase-chip" id="phase-nmap">Nmap</div>
            <div class="phase-chip" id="phase-recon">Recon</div>
            <div class="phase-chip" id="phase-msf">Metasploit</div>
            <div class="phase-chip" id="phase-ai">AI</div>
            <div class="phase-chip" id="phase-completed">Completed</div>
        </div>
    </div>
</section>

<section class="card">
    <div class="section-title">What Happens Next</div>
    <p class="muted">
        After the scan completes, you will be automatically redirected to the full result page for that scan.
    </p>
</section>
{% endblock %}
