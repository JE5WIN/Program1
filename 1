# ---------------- API ----------------
@app.route("/api/scan", methods=["POST"])
def api_scan():
    data = request.get_json()
    target = data.get("target")
    if not target:
        return {"error": "Target required"}, 400

    scan_id = str(uuid.uuid4())
    scan_status[scan_id] = "Starting"

    # Start background scan
    thread = threading.Thread(target=run_scan_background, args=(scan_id, target))
    thread.start()

    return jsonify({"scan_id": scan_id, "status": "started"})

@app.route("/api/status/<scan_id>")
def api_status(scan_id):
    return {"status": scan_status.get(scan_id, "Unknown")}

@app.route("/api/result/<scan_id>")
def api_result(scan_id):
    file_path = f"storage/findings/{scan_id}.json"
    if not os.path.exists(file_path):
        return {"error": "Not ready"}, 404

    with open(file_path) as f:
        return json.load(f)

@app.route("/api/scans")
def list_scans():
    scans = []
    for file in os.listdir("storage/findings"):
        if file.endswith(".json"):
            with open(os.path.join("storage/findings", file)) as f:
                data = json.load(f)
            scans.append({
                "scan_id": data.get("scan_id"),
                "target": data.get("target"),
                "timestamp": data.get("timestamp"),
                "status": data.get("status", "Unknown")
            })
    return jsonify(scans)

# ---------------- PDF EXPORT ----------------
@app.route("/api/report/pdf/<scan_id>")
def generate_pdf(scan_id):
    from io import BytesIO
    from flask import send_file

    file_path = f"storage/findings/{scan_id}.json"
    if not os.path.exists(file_path):
        return {"error": "Not found"}, 404

    with open(file_path) as f:
        data = json.load(f)

    buffer = BytesIO()
    doc = SimpleDocTemplate(buffer)
    styles = getSampleStyleSheet()
    content = []

    # Add main scan details
    content.append(Paragraph(f"Target: {data['target']}", styles["Normal"]))
    content.append(Paragraph(f"Timestamp: {data['timestamp']}", styles["Normal"]))
    content.append(Paragraph(f"Summary: {data['summary']}", styles["Normal"]))

    # Findings
    for i, finding in enumerate(data.get("findings", []), 1):
        content.append(Paragraph(f"Finding {i}:", styles["Normal"]))
        content.append(Paragraph(json.dumps(finding, indent=2), styles["Normal"]))

    # Attack chain
    content.append(Paragraph("Attack Chain:", styles["Normal"]))
    content.append(Paragraph(json.dumps(data.get("attack_chain", []), indent=2), styles["Normal"]))

    doc.build(content)
    buffer.seek(0)
    return send_file(buffer, as_attachment=True, download_name=f"{scan_id}.pdf", mimetype="application/pdf")

